// Generated by Hytale UI Builder (https://hytale.ellie.au).
$Hotbar = "Hotbar.ui";
Group {
  LayoutMode: Top;
  Anchor: (Top: 30, Width: 800, Height: 500);
  Label #BossName {
    Anchor: (Left: 0, Right: 0, Horizontal: 0);
    Text: "Nom Boss";
    Style: (FontSize: 25, RenderBold: true, VerticalAlignment: Center, Alignment: Center, TextColor: #ffffff, HorizontalAlignment: Center);
  }
  Group {
    Anchor: (Width: 1000, Height: 70);
    Background: "mikaela_bar.png";

    ProgressBar #BossHealthBarYellow {
      Anchor: (Width: 1000, Height: 70);
      Value: 1.0;
      BarTexturePath: "mikaela_fill_yellow.png";
      Visible: true;
    }
    ProgressBar #BossHealthBarOrange {
      Anchor: (Width: 1000, Height: 70);
      Value: 1.0;
      BarTexturePath: "mikaela_fill_orange.png";
      Visible: false;
    }
    ProgressBar #BossHealthBarRed {
      Anchor: (Width: 1000, Height: 70);
      Value: 1.0;
      BarTexturePath: "mikaela_fill_red.png";
      Visible: false;
    }
  }
}